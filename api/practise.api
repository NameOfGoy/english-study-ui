syntax = "v1"

type WordCard {
	ID          uint     `json:"id"` // 词语ID
	Word        string   `json:"word"` // 词语
	WordType    int      `json:"word_type"` // 单词类型, 1-单词 2-短语
	UKPhonetic  string   `json:"uk_phonetic"` // 英式音标
	UKAudio     string   `json:"uk_audio"` // 英式音频
	USPhonetic  string   `json:"us_phonetic"` // 美式音标
	USAudio     string   `json:"us_audio"` // 美式音频
	Translation string   `json:"translation"` // 翻译
	Example     []string `json:"example"` // 例句
	Picture     []string `json:"picture"` // 图片
}

type GetWordCardListReq {
	Count  int  `form:"count,default=10"` // 单词数量
	Random bool `form:"random"` // 是否随机
	WordType int `form:"word_type"` // 单词类型 0-都行 1-单词 2-短语
}

type GetWordCardListResp {
	CommonReply
	Data []*WordCard `json:"data"`
}

@server (
	group:  practise
	jwt:    Auth
	prefix: api/v1/practise/study // 学习模式
)
service englishstudy-api {
	@doc "学习模式/获取单词列表"
	@handler GetStudyWordCardList
	get /list (GetWordCardListReq) returns (GetWordCardListResp)

	@doc "学习模式/完成学习"
	@handler FinishStudy
	post /finish (FinishStudyReq) returns (FinishStudyResp)
}

type FinishStudyReq {
	WordID uint `json:"word_id"` // 单词ID
	WordType int  `json:"word_type"` // 单词类型 1-单词 2-短语
}

type FinishStudyResp {
	CommonReply
}

@server (
	group:  practise
	jwt:    Auth
	prefix: api/v1/practise/review // 复习模式
)
service englishstudy-api {
	@doc "复习模式/获取单词列表"
	@handler GetReviewWordCardList
	get /list (GetWordCardListReq) returns (GetWordCardListResp)

	@doc "复习模式/完成复习"
	@handler FinishReview
	post /finish (FinishReviewReq) returns (FinishReviewResp)
}

type FinishReviewReq {
	WordID    uint `json:"word_id"` // 单词ID
	WordType  int  `json:"word_type"` // 单词类型 1-单词 2-短语
	Operation int  `json:"operation"` // 操作 1-完成复习 2-复习失败
}

type FinishReviewResp {
	CommonReply
}

