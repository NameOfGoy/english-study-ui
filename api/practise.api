@server (
	group:  practise
	jwt:    Auth
	prefix: api/v1/practise/spot // 抽查模式
)
service englishstudy-api {
	@doc "抽查模式/获取单词列表"
	@handler GetSpotWordCardList
	get /list (GetWordCardListReq) returns (GetWordCardListResp)

	@doc "抽查模式/完成抽查"
	@handler FinishSpot
	post /finish (FinishSpotReq) returns (FinishSpotResp)
}

type FinishSpotReq {
	WordID    uint `json:"word_id"` // 单词ID
	WordType  int  `json:"word_type"` // 单词类型 1-单词 2-短语
	Operation int  `json:"operation"` // 操作 1-完成抽查 2-抽查失败
}

type FinishSpotResp {
	CommonReply
}

